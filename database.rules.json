{
  "rules": {
    "trips": {
      "$tripId": {
        "info": {
          ".read":     "auth != null",
          ".write":    "auth != null && !data.exists()",
          ".validate": "newData.hasChildren(['customerPhone', 'pickupGeohash', 'dropGeohash', 'vehicleType', 'createdAt']) && newData.child('vehicleType').val().matches(/^(motorbike|car4|car7|pickup)$/) && newData.child('createdAt').isNumber()"
        },
        "quotes": {
          ".read": "auth != null",
          "$driverUid": {
            ".write":    "auth != null && auth.uid == $driverUid",
            ".validate": "newData.hasChildren(['quotedPrice', 'driverUid', 'driverName', 'vehicleBrand', 'licensePlate', 'rating', 'createdAt']) && newData.child('quotedPrice').isNumber() && newData.child('quotedPrice').val() > 0"
          }
        },
        "location": {
          ".read":     "auth != null",
          ".write":    "auth != null",
          ".validate": "newData.hasChildren(['lat', 'lng', 'timestamp']) && newData.child('lat').isNumber() && newData.child('lng').isNumber() && newData.child('timestamp').isNumber()"
        },
        "trip_status": {
          ".read":     "auth != null",
          ".write":    "auth != null",
          ".validate": "newData.isString() && newData.val().matches(/^(picked_up|completed)$/)"
        },
        "trip_info": {
          ".read":     "auth != null",
          ".write":    "auth != null",
          ".validate": "newData.hasChildren(['driverName', 'driverPhone', 'vehicleBrand', 'licensePlate'])"
        },
        "rating": {
          ".read":     "auth != null",
          ".write":    "auth != null",
          ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 5"
        },
        ".write": "auth != null && !newData.exists()"
      }
    },
    "drivers_online": {
      "$uid": {
        ".read":     "auth != null",
        ".write":    "auth != null && auth.uid == $uid",
        ".validate": "newData.hasChildren(['lastSeen']) && newData.child('lastSeen').isNumber() && newData.child('lastSeen').val() <= now"
      }
    },
    "$other": {
      ".read":  false,
      ".write": false
    }
  }
}
